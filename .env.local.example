# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.
#
#   cp .env.local.example .env.local

# ── Required ─────────────────────────────────────────────────────────────────
# AI provider. Supported: anthropic, openai, gemini.
# Anthropic is the default when AI_PROVIDER is omitted.
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6

# Provider keys. Set the key for whichever AI_PROVIDER you use.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# Postgres connection string (used by coordinator + intake tables)
DATABASE_URL_FOR_ALEMBIC=<postgres-connection-url>

# ── Live email loop (scenarios 7 + 8) ────────────────────────────────────────
# Gmail App Password works for both SMTP send and IMAP receive.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=privacy-agent@example.com
SMTP_PASS=<smtp-app-password>

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=privacy-agent@example.com
IMAP_PASS=<imap-app-password>

EMAIL_FROM_NAME=Izzy Privacy and Governance

# ── Optional: Resend API (alternative transactional email) ───────────────────
# RESEND_API_KEY=re_...

# ── Gmail OAuth (prod / Railway — bypasses SMTP egress block) ────────────────
# See CLAUDE.md "Gmail OAuth — one-time setup" for instructions.
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
# GMAIL_USER_EMAIL=privacy-agent@example.com
# OAUTH_REDIRECT_URI=https://your-domain.example/api/oauth/gmail/callback

# ── Operator email redirect (demo safety net) ────────────────────────────────
# When set, ALL coordinator outbound is redirected here regardless of recipient.
# Unset to send to the actual case recipient.
# EMAIL_OVERRIDE_TO=you@example.com

# ── Izzy email allowlist ──────────────────────────────────────────────────────
# Comma-separated list of operator emails allowed to email Izzy and get a reply.
# Overrides IZZY_EMAIL_ALLOWLIST_DEFAULT in src/lib/constants.ts.
# IZZY_EMAIL_ALLOWLIST=you@example.com,colleague@example.com

# ── Cron auth ────────────────────────────────────────────────────────────────
# Bearer secret for POST /api/cron/ingest-replies
CRON_SECRET=<random-secret>

# ── Calendly (optional landing page CTA) ─────────────────────────────────────
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-link/30min

# ── PPTX output directory ────────────────────────────────────────────────────
# Where generated .pptx files are saved. Defaults shown below.
# PIPELINE_OUTPUT_DIR=/Users/you/Documents/Instrata          # local
# PIPELINE_OUTPUT_DIR=/tmp/instrata-pptx                     # prod (Railway ephemeral)
